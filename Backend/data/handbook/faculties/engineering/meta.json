  "course_code_system": {
    "description": "Eight character code AAAnnnnB: AAA=department, nnnn=year level+number, B=suffix.",
    "handbook_page": 11,
    "suffix_codes": {
      "A": {"meaning": "1st quarter course", "semester": "Q1"},
      "B": {"meaning": "2nd quarter course", "semester": "Q2"},
      "C": {"meaning": "3rd quarter course", "semester": "Q3"},
      "D": {"meaning": "4th quarter course", "semester": "Q4"},
      "F": {"meaning": "First semester course", "semester": "S1"},
      "S": {"meaning": "Second semester course", "semester": "S2"},
      "H": {"meaning": "Half course taught over whole year", "semester": "FY"},
      "W": {"meaning": "Full course, year-long", "semester": "FY"},
      "L": {"meaning": "Winter term", "semester": "winter"},
      "M": {"meaning": "Multiterm", "semester": "varies"},
      "U": {"meaning": "Summer Term Sessions 1 and 2", "semester": "summer"},
      "J": {"meaning": "Summer Term Session 1", "semester": "summer"},
      "P": {"meaning": "Summer Term Session 2", "semester": "summer"},
      "X": {"meaning": "Not classified (e.g. practical training)", "semester": "varies"},
      "Z": {"meaning": "Other", "semester": "varies"}
    },
    "note": "Levels 1-3 are undergraduate. Level 4 CHE/CIV/EEE/MEC courses are undergraduate; level 4 APG (non-Geomatics) and CON are postgraduate. Level 5+ is postgraduate."
  },
